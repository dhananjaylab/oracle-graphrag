# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Oracle DBs (one block per entry in databases.yaml) ────────────────────────
# DB 1 — Core Banking (env_prefix: FINCORE)
FINCORE_USER=fincore_user
FINCORE_PASSWORD=your-fincore-password
FINCORE_DSN=host1:1521/FINCORE

# DB 2 — Risk Management (env_prefix: RISKDB)
RISKDB_USER=risk_user
RISKDB_PASSWORD=your-riskdb-password
RISKDB_DSN=host2:1521/RISKDB
