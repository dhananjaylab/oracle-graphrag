# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# IMPORTANT: Only schema metadata (table/column names) is sent to Gemini.
# No actual row data ever leaves your on-prem network.
GEMINI_API_KEY=AIza...

# ── Oracle DB ─────────────────────────────────────────────────────────────────
# DSN format: host:port/service_name  e.g. 192.168.1.10:1521/ORCL
ORACLE_USER=your_db_user
ORACLE_PASSWORD=your_db_password
ORACLE_DSN=host:1521/service_name

# Schema to introspect (leave empty to include all accessible schemas)
# For banking: typically your app schema e.g. FINCORE, BANKDB
ORACLE_SCHEMA=YOUR_SCHEMA

# ── Neo4j (on-prem) ───────────────────────────────────────────────────────────
# After installing Neo4j 5.x: https://neo4j.com/deployment-center/
# Default local URI: bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
